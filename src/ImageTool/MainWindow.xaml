<Window x:Class="ImageTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageTool"
        xmlns:vm="clr-namespace:ImageTool.ViewModels"
        xmlns:conv="clr-namespace:ImageTool.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="ImageTool - HSV Filter &amp; OCR" Height="720" Width="1280">
    <Window.InputBindings>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteImageCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:CheckerSizeToRectConverter x:Key="CheckerSizeToRectConverter"/>
        <conv:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
        <!-- DrawingBrush for Checkered Background -->
        <DrawingBrush x:Key="CheckeredBrush" TileMode="Tile" ViewportUnits="Absolute">
            <DrawingBrush.Viewport>
                <Binding Path="CheckerSize" Converter="{StaticResource CheckerSizeToRectConverter}"/>
            </DrawingBrush.Viewport>
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,20,20"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFE0E0E0">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,10,10"/>
                                <RectangleGeometry Rect="10,10,10,10"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding ControlPanelWidth, Converter={StaticResource DoubleToGridLengthConverter}, Mode=TwoWay}" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Grid Splitter -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      ShowsPreview="True" Width="5" Background="#EEE"/>

        <!-- Left Panel: Controls -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Open Button -->
            <Button Grid.Row="0" Content="Open Image" Command="{Binding OpenImageCommand}" Margin="0,0,0,10"/>

            <!-- Middle: Filters (Fill remaining space) -->
            <GroupBox Grid.Row="1" Header="Danh sách bộ lọc (HSV Color Filtering)" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Thêm bộ lọc mới" Command="{Binding AddFilterCommand}" Margin="5"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Filters}" HorizontalContentAlignment="Stretch" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left column: Toggle and Name/Note -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,5,10,0">
                                        <CheckBox IsChecked="{Binding IsUsed}" Content="Sử dụng" FontSize="10"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="11" FontWeight="SemiBold" Margin="0,5,0,0" Foreground="Navy"/>
                                        <xctk:WatermarkTextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" 
                                                              FontSize="9" Margin="0,5,0,0" Watermark="Ghi chú..."/>
                                    </StackPanel>

                                    <!-- Middle column: The 3 Sliders -->
                                    <StackPanel Grid.Column="1">
                                        <!-- H Slider -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="H:" VerticalAlignment="Center" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="{Binding HMin, StringFormat={}{0:0}}" VerticalAlignment="Center" FontSize="9" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                            <xctk:RangeSlider Grid.Column="2" Minimum="0" Maximum="180" 
                                                              LowerValue="{Binding HMin}" HigherValue="{Binding HMax}">
                                                <xctk:RangeSlider.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="Red" Offset="0.0"/>
                                                        <GradientStop Color="Yellow" Offset="0.16"/>
                                                        <GradientStop Color="Lime" Offset="0.33"/>
                                                        <GradientStop Color="Cyan" Offset="0.5"/>
                                                        <GradientStop Color="Blue" Offset="0.66"/>
                                                        <GradientStop Color="Magenta" Offset="0.83"/>
                                                        <GradientStop Color="Red" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </xctk:RangeSlider.Background>
                                            </xctk:RangeSlider>
                                            <TextBlock Grid.Column="3" Text="{Binding HMax, StringFormat={}{0:0}}" VerticalAlignment="Center" FontSize="9" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                                        </Grid>

                                        <!-- S Slider -->
                                        <Grid Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="S:" VerticalAlignment="Center" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SMin, StringFormat={}{0:0}}" VerticalAlignment="Center" FontSize="9" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                            <xctk:RangeSlider Grid.Column="2" Minimum="0" Maximum="255" 
                                                              LowerValue="{Binding SMin}" HigherValue="{Binding SMax}">
                                                <xctk:RangeSlider.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="White" Offset="0"/>
                                                        <GradientStop Color="#00BFA5" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </xctk:RangeSlider.Background>
                                            </xctk:RangeSlider>
                                            <TextBlock Grid.Column="3" Text="{Binding SMax, StringFormat={}{0:0}}" VerticalAlignment="Center" FontSize="9" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                                        </Grid>

                                        <!-- V Slider -->
                                        <Grid Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="V:" VerticalAlignment="Center" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="{Binding VMin, StringFormat={}{0:0}}" VerticalAlignment="Center" FontSize="9" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                            <xctk:RangeSlider Grid.Column="2" Minimum="0" Maximum="255" 
                                                              LowerValue="{Binding VMin}" HigherValue="{Binding VMax}">
                                                <xctk:RangeSlider.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="Black" Offset="0"/>
                                                        <GradientStop Color="White" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </xctk:RangeSlider.Background>
                                            </xctk:RangeSlider>
                                            <TextBlock Grid.Column="3" Text="{Binding VMax, StringFormat={}{0:0}}" VerticalAlignment="Center" FontSize="9" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Right column: Remove Button -->
                                    <Button Grid.Column="2" Content="X" 
                                            Command="{Binding DataContext.RemoveFilterCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Top" HorizontalAlignment="Right"
                                            Width="20" Height="20" Padding="0" Margin="0,5,0,0" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>

            <!-- Bottom: Other Controls -->
            <StackPanel Grid.Row="2">
                <GroupBox Header="Chế độ hiển thị kết quả" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Gray (mask)" 
                                         IsChecked="{Binding ResultPreviewMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Gray}"
                                         Margin="0,0,10,0" FontSize="11"/>
                            <RadioButton Content="Bgra (mask đã áp vào alpha)" 
                                         IsChecked="{Binding ResultPreviewMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Bgra}"
                                         FontSize="11"/>
                        </StackPanel>
                        <CheckBox Content="Đảo ngược màu (Invert Mask)" 
                                  IsChecked="{Binding IsInvertMask}" 
                                  Margin="0,5,0,0" FontSize="11"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,0,0,10">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsOcrEnabled}" VerticalAlignment="Center"/>
                            <TextBlock Text="Tiền xử lý OCR (Pre-processing)" Margin="5,0,0,0" FontWeight="Bold"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel IsEnabled="{Binding IsOcrEnabled}">

                        <!-- Language + Run OCR -->
                        <Grid Margin="0,5,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ngôn ngữ:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding OcrLanguages}"
                                      SelectedItem="{Binding OcrLanguage}"
                                      VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Content="▶ OCR"
                                    Command="{Binding RunOcrCommand}"
                                    Margin="6,0,0,0" Padding="6,2"
                                    FontSize="11"
                                    IsEnabled="{Binding IsOcrRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>

                        <!-- Scale Factor -->
                        <Grid Margin="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,2">
                                <CheckBox IsChecked="{Binding IsOcrScaleEnabled}" VerticalAlignment="Center"/>
                                <TextBlock Text="Scale Factor" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="0.1" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" IsEnabled="{Binding IsOcrScaleEnabled}"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0.1" Maximum="5" 
                                    Value="{Binding OcrScaleFactor}" 
                                    IsEnabled="{Binding IsOcrScaleEnabled}"
                                    AutoToolTipPlacement="BottomRight" AutoToolTipPrecision="1"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="5" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0" IsEnabled="{Binding IsOcrScaleEnabled}"/>
                        </Grid>
                        
                        <!-- Erosion Size -->
                        <Grid Margin="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,2">
                                <CheckBox IsChecked="{Binding IsOcrErosionEnabled}" VerticalAlignment="Center"/>
                                <TextBlock Text="Erosion Size" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="0" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" IsEnabled="{Binding IsOcrErosionEnabled}"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="10" 
                                    Value="{Binding OcrErosionSize}" 
                                    IsEnabled="{Binding IsOcrErosionEnabled}"
                                    AutoToolTipPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="10" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0" IsEnabled="{Binding IsOcrErosionEnabled}"/>
                        </Grid>
                        
                        <!-- Dilation Size -->
                        <Grid Margin="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,2">
                                <CheckBox IsChecked="{Binding IsOcrDilationEnabled}" VerticalAlignment="Center"/>
                                <TextBlock Text="Dilation Size" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="0" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" IsEnabled="{Binding IsOcrDilationEnabled}"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="10" 
                                    Value="{Binding OcrDilationSize}" 
                                    IsEnabled="{Binding IsOcrDilationEnabled}"
                                    AutoToolTipPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="10" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0" IsEnabled="{Binding IsOcrDilationEnabled}"/>
                        </Grid>
                        
                        <!-- Closing Size -->
                        <Grid Margin="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,2">
                                <CheckBox IsChecked="{Binding IsOcrClosingEnabled}" VerticalAlignment="Center"/>
                                <TextBlock Text="Closing Size" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="0" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" IsEnabled="{Binding IsOcrClosingEnabled}"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="10" 
                                    Value="{Binding OcrClosingSize}" 
                                    IsEnabled="{Binding IsOcrClosingEnabled}"
                                    AutoToolTipPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="10" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0" IsEnabled="{Binding IsOcrClosingEnabled}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Nền xem trước (Background)" Margin="0,0,0,10">
                    <StackPanel>
                        <RadioButton Content="Nền carô" IsChecked="{Binding IsSolidBackground, Converter={StaticResource InverseBooleanConverter}}" Margin="0,5"/>
                        <StackPanel Margin="20,0,10,5" IsEnabled="{Binding IsSolidBackground, Converter={StaticResource InverseBooleanConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="5" Maximum="100" Value="{Binding CheckerSize, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CheckerSize, StringFormat={}{0:0}}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <RadioButton Content="Màu đơn sắc" IsChecked="{Binding IsSolidBackground}" Margin="0,5"/>
                        <StackPanel Margin="20,0,10,5" IsEnabled="{Binding IsSolidBackground}">
                            <xctk:ColorPicker SelectedColor="{Binding SelectedBackgroundColor}" ShowAvailableColors="True" DisplayColorAndName="True"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- Right Panel: Preview -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ImageSplitterHeight, Converter={StaticResource DoubleToGridLengthConverter}, Mode=TwoWay}" MinHeight="100"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Grid Splitter -->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          ShowsPreview="True" Height="5" Background="#EEE"/>

            <!-- Original Image Preview -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="5">
                <Grid Background="#F0F0F0" ClipToBounds="True">
                    <ScrollViewer x:Name="OriginalScrollViewer" 
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="OriginalPreview_MouseWheel"
                                  PreviewMouseDown="OriginalPreview_MouseDown"
                                  PreviewMouseMove="OriginalPreview_MouseMove"
                                  PreviewMouseUp="OriginalPreview_MouseUp">
                        <Image Source="{Binding OriginalImage}" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="OriginalScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                    <TextBlock Text="Original Viewport (Scroll to Zoom, Drag to Pan)" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="#888" IsHitTestVisible="False"
                               Visibility="{Binding OriginalImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </Grid>
            </Border>


            <!-- Processed Image Preview -->
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="5">
                <Grid ClipToBounds="True">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Background" Value="{StaticResource CheckeredBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSolidBackground}" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding SelectedBackgroundColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <ScrollViewer x:Name="ProcessedScrollViewer" 
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="ProcessedPreview_MouseWheel"
                                  PreviewMouseDown="ProcessedPreview_MouseDown"
                                  PreviewMouseMove="ProcessedPreview_MouseMove"
                                  PreviewMouseUp="ProcessedPreview_MouseUp">
                        <Grid>
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="ProcessedScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Grid.LayoutTransform>
                            
                            <Image Source="{Binding ProcessedImage}" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            
                            <!-- OCR Overlay Canvas inside the same scaling container -->
                            <Canvas x:Name="OcrCanvas" IsHitTestVisible="True" Background="Transparent"
                                    Width="{Binding ProcessedImage.Width}"
                                    Height="{Binding ProcessedImage.Height}">
                                <ItemsControl ItemsSource="{Binding OcrResults}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas IsItemsHost="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Bounds.X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Bounds.Y}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,-16,0,0">
                                                <TextBlock Text="{Binding Text}" 
                                                           Foreground="Red" 
                                                           Background="#88FFFFFF"
                                                           FontSize="10" 
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Left"
                                                           IsHitTestVisible="False"/>
                                                <Border BorderBrush="Red" BorderThickness="1"
                                                        Width="{Binding Bounds.Width}"
                                                        Height="{Binding Bounds.Height}"
                                                        Background="Transparent"
                                                        Cursor="Arrow"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

